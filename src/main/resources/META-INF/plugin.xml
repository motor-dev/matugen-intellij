<idea-plugin>
    <id>com.matugen.theme</id>
    <name>Matugen Dynamic Color Scheme</name>
    <vendor email="motor.devel@gmail.com">Matugen</vendor>

    <description><![CDATA[
        Dynamically applies IDE editor color schemes from a watched config file generated by
        <a href="https://github.com/InioX/matugen">matugen</a> (Material You color generation).
        <br><br>
        Point the plugin at your matugen output file and the IDE colors will update live whenever
        matugen regenerates the palette.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Bootstraps the file watcher after the IDE has finished starting up -->
        <postStartupActivity
            implementation="com.matugen.theme.startup.MatugenStartupActivity"/>

        <!-- Persisted settings -->
        <applicationService
            serviceImplementation="com.matugen.theme.settings.MatugenSettings"/>

        <!-- Core service: watches the config file and drives scheme updates -->
        <applicationService
            serviceImplementation="com.matugen.theme.services.FileWatcherService"/>

        <!-- Settings UI in Preferences → Appearance & Behavior → Matugen -->
        <applicationConfigurable
            parentId="appearance"
            instance="com.matugen.theme.settings.MatugenSettingsConfigurable"
            id="com.matugen.theme.settings"
            displayName="Matugen Dynamic Colors"/>

        <!-- Notification group for user-facing status messages -->
        <notificationGroup
            id="Matugen"
            displayType="BALLOON"/>
    </extensions>

    <actions>
        <action id="com.matugen.theme.actions.ReloadSchemeAction"
                class="com.matugen.theme.actions.ReloadSchemeAction"
                text="Reload Matugen Color Scheme"
                description="Force-reload colors from the watched config file">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
